# --- Shopify (custom app Admin API access token) -------------------------
# Create a custom app in your Shopify admin (Settings → Apps and sales
# channels → Develop apps), grant read_orders + write_orders, and install it.
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10

# --- Sham Cash API (read-only) --------------------------------------------
SHAMCASH_API_BASE=https://api.shamcash-api.com/v1
SHAMCASH_API_TOKEN=your-sham-cash-bearer-token
SHAMCASH_ACCOUNT_ID=your-account-id

# Name of the Shopify *manual payment method* to reconcile (must match exactly
# what you named it under Settings → Payments → Manual payment methods).
SHAMCASH_GATEWAY_NAME=Sham Cash

# --- Matching -------------------------------------------------------------
# note | amount | both   (default: both = reference/note first, then amount)
SHAMCASH_MATCH_MODE=both
SHAMCASH_AMOUNT_TOLERANCE=0
SHAMCASH_ALLOWED_CURRENCIES=SYP,USD,TRY
# Optional currency -> coin_id map for the /transactions filter
SHAMCASH_COIN_MAP=
SHAMCASH_TIME_WINDOW_GRACE=30
SHAMCASH_ORDER_MAX_AGE=1440

# --- Worker ---------------------------------------------------------------
SHAMCASH_POLL_INTERVAL_SECONDS=300
SHAMCASH_LEDGER_PATH=./data/claims.json
SHAMCASH_DEBUG=false
